# ──────────────────────────────────────────────
# SPECTAGLINT Backend — Environment Variables
# Copy this file to .env for local dev (never commit .env to git)
# On Railway: set these in the Railway dashboard under Variables
# ──────────────────────────────────────────────

# Supabase — Auth only (JWT verification)
# Get from: Supabase Dashboard → Settings → API → Project API Keys
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Railway PostgreSQL — Auto-provided when you add a Postgres plugin on Railway
# Format: postgresql://user:password@host.railway.internal:5432/railway
DATABASE_URL=postgresql://postgres:password@host.railway.internal:5432/railway

# Groq — Whisper transcription + Llama inference
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Stripe — Payment processing
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Frontend URL — Used for Stripe redirect URLs + CORS allow list
# Set to your Vercel/Netlify deployment URL
FRONTEND_URL=https://your-frontend.vercel.app

# Server
PORT=3000
NODE_ENV=production
